<ContentPage
    x:Class="LocalDisasterPreventionInformationApp.Pages.Stock.ProductRegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:LocalDisasterPreventionInformationApp.Pages.Base"
    Shell.NavBarIsVisible="False">

    <base:BasePage>
        <base:BasePage.InnerContent>

            <VerticalStackLayout Padding="20"
                                 Spacing="15"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">

                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                      ColumnSpacing="30"
                      RowSpacing="50"
                      HorizontalOptions="Center"
                      VerticalOptions="Center">

                    <!-- 商品名 -->
                    <Label Text="{Binding Stock_ProductName}"
                           Grid.Row="0" Grid.Column="0"
                           VerticalOptions="Center"
                           FontSize="20"
                           HorizontalTextAlignment="End"/>

                    <Entry x:Name="ProductNameEntry"
                           Grid.Row="0" Grid.Column="1"
                           Placeholder="{Binding Stock_ProductName}"
                           FontSize="17"
                           WidthRequest="250"/>

                    <!-- 消費期限 -->
                    <Label Text="{Binding Stock_Expire}"
                           Grid.Row="1" Grid.Column="0"
                           VerticalOptions="Center"
                           FontSize="20"
                           HorizontalTextAlignment="End"/>

                    <DatePicker x:Name="ExpirationPicker"
                                Grid.Row="1" Grid.Column="1"
                                FontSize="17"
                                WidthRequest="250"
                                Format="yyyy/MM/dd" />


                    <!-- 数量 -->
                    <Label Text="{Binding Stock_Quantity}"
                           Grid.Row="2" Grid.Column="0"
                           VerticalOptions="Center"
                           FontSize="20"
                           HorizontalTextAlignment="End"/>

                    <Entry x:Name="QuantityEntry"
                           Grid.Row="2" Grid.Column="1"
                           Placeholder="{Binding Stock_Quantity}"
                           FontSize="17"
                           WidthRequest="250"
                           Keyboard="Numeric"
                           TextChanged="OnQuantityChanged"/>

                    <!-- カテゴリ -->
                    <Label Text="{Binding Stock_Category}"
                           Grid.Row="3" Grid.Column="0"
                           VerticalOptions="Center"
                           FontSize="20"
                           HorizontalTextAlignment="End"/>

                    <Picker x:Name="CategoryPicker"
                            Grid.Row="3" Grid.Column="1"
                            FontSize="17"
                            WidthRequest="250">
                    </Picker>

                    <Label Text="v"
                           Grid.Row="3" Grid.Column="1"
                           FontSize="20"
                           TextColor="gray"
                           HorizontalOptions="End"
                           VerticalOptions="Center"
                           Margin="5,0,20,0"/>


                </Grid>

                <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">

                    <!-- 戻るボタン -->
                    <Button Text="{Binding Btn_Back}"
                            BackgroundColor="#B2BEB5"
                            TextColor="White"
                            FontSize="20"
                            CornerRadius="10"
                            WidthRequest="120"
                            Margin="10,0"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Clicked="OnBackClicked"/>

                    <!-- 登録ボタン -->
                    <Button Text="{Binding Btn_Register}"
                            BackgroundColor="#8CAFA4"
                            TextColor="White"
                            FontSize="20"
                            CornerRadius="10"
                            WidthRequest="120"
                            Margin="10,0"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Clicked="OnSubmitClicked"/>

                </HorizontalStackLayout>
            </VerticalStackLayout>

        </base:BasePage.InnerContent>
    </base:BasePage>
</ContentPage>