<ContentPage

    x:Class="LocalDisasterPreventionInformationApp.Pages.Stock.StockPage"

    x:Name="ThisPage"

    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"

    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"

    xmlns:base="clr-namespace:LocalDisasterPreventionInformationApp.Pages.Base"

    Shell.NavBarIsVisible="False">

    <base:BasePage>
        <base:BasePage.InnerContent>

            <Grid x:Name="Inner"

                  RowDefinitions="Auto,Auto,*,Auto"

                  Padding="10">

                <!-- 期限が近い・期限切れ商品 -->
                <Border Stroke="Gray"

                        StrokeThickness="1"

                        BackgroundColor="Transparent"

                        Padding="10"

                        StrokeShape="RoundRectangle 8"

                        HeightRequest="130">

                    <VerticalStackLayout Grid.Row="0"

                                         HorizontalOptions="Center"

                                         VerticalOptions="Start"

                                         Spacing="4">

                        <!-- タイトル（消費期限順） -->
                        <Label Text="{Binding Stock_ExpireOrder}"

                               FontAttributes="Bold"

                               FontSize="18"

                               HorizontalOptions="Center"/>

                        <BindableLayout.ItemsSource>
                            <Binding  Source="{x:Reference ThisPage}" Path="ExpiringItems"/>
                        </BindableLayout.ItemsSource>

                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding Message}"

                                       TextColor="Red"

                                       FontSize="16"

                                       Margin="0,2"

                                       HorizontalOptions="Start"/>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>

                    </VerticalStackLayout>
                </Border>

                <!-- 並べ替え -->
                <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto" Margin="0,10">

                    <!-- 並べ替え Picker -->
                    <Picker x:Name="SortPicker"
                            FontSize="26"
                            Grid.Column="0"
                            WidthRequest="260"
                            HeightRequest="60"
                            SelectedIndexChanged="OnSortChanged"/>

                    <Label Text="v"
                           FontSize="28"
                           TextColor="gray"
                           HorizontalOptions="End"
                           VerticalOptions="Center"
                           Margin="5,0"/>
                </Grid>

                <!-- 商品一覧 -->
                <CollectionView Grid.Row="2"

                                ItemsSource="{Binding Source={x:Reference ThisPage},Path=Items}"

                                HorizontalOptions="Center"

                                WidthRequest="900">

                    <CollectionView.Header>
                        <VerticalStackLayout Spacing="0">

                            <!-- 9カラム構成に変更 -->
                            <Grid ColumnDefinitions="2*,1,3*,1,2*,1,2*,1,*"
                                  MaximumWidthRequest="750"
                                  Padding="5" BackgroundColor="#EEEEEE">

                                <!-- 商品名 -->
                                <Label Grid.Column="0"
                                   Text="{Binding Stock_ProductName}"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>

                                <!-- 縦線 -->
                                <BoxView Grid.Column="1"
                                   BackgroundColor="#CCCCCC"
                                   VerticalOptions="Fill"/>

                                <!-- 数量 -->
                                <Label Grid.Column="2"
                                   Text="{Binding Stock_Quantity}"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>

                                <!-- 縦線 -->
                                <BoxView Grid.Column="3"
                                   BackgroundColor="#CCCCCC"
                                   VerticalOptions="Fill"/>

                                <!-- 消費期限 -->
                                <Label Grid.Column="4"
                                   Text="{Binding Stock_Expire}"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>

                                <!-- 縦線 -->
                                <BoxView Grid.Column="5"
                                   BackgroundColor="#CCCCCC"
                                   VerticalOptions="Fill"/>

                                <!-- カテゴリ -->
                                <Label Grid.Column="6"
                                   Text="{Binding Stock_Category}"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>

                                <!-- 縦線 -->
                                <BoxView Grid.Column="7"
                                   BackgroundColor="#CCCCCC"
                                   VerticalOptions="Fill"/>

                                <!-- 削除 -->
                                <Label Grid.Column="8"
                                   Text="{Binding Stock_Delete}"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>
                            </Grid>

                            <!-- 黒い線 -->
                            <BoxView HeightRequest="1"
                                 BackgroundColor="Black"
                                 MaximumWidthRequest="750" />
                        </VerticalStackLayout>
                    </CollectionView.Header>


                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <VerticalStackLayout Spacing="0">

                                <!-- ★ 9カラム構成（縦線専用カラムを追加） -->
                                <Grid ColumnDefinitions="2*,1,3*,1,2*,1,2*,1,*"
                                      MaximumWidthRequest="750"
                                      Padding="5">

                                    <!-- 縦線（商品名と数量の間） -->
                                    <BoxView Grid.Column="1"
                                         BackgroundColor="#CCCCCC"
                                         VerticalOptions="Fill"/>

                                    <!-- 縦線（数量と消費期限の間） -->
                                    <BoxView Grid.Column="3"
                                         BackgroundColor="#CCCCCC"
                                         VerticalOptions="Fill"/>

                                    <!-- 縦線（消費期限とカテゴリの間） -->
                                    <BoxView Grid.Column="5"
                                         BackgroundColor="#CCCCCC"
                                         VerticalOptions="Fill"/>

                                    <!-- 縦線（カテゴリと削除の間） -->
                                    <BoxView Grid.Column="7"
                                         BackgroundColor="#CCCCCC"
                                         VerticalOptions="Fill"/>

                                    <!-- 商品名 -->
                                    <Label Grid.Column="0"
                                         Text="{Binding ProductName}"
                                         VerticalOptions="Center"
                                         HorizontalOptions="Center"/>

                                    <!-- 数量＋増減ボタン -->
                                    <Grid Grid.Column="2"
                                         ColumnDefinitions="100,30,100"
                                         HorizontalOptions="Center"
                                         ColumnSpacing="4">

                                        <!-- －ボタン -->
                                        <Button Grid.Column="0"
                                            Text="－"
                                            FontSize="20"
                                            WidthRequest="24"
                                            HeightRequest="24"
                                            BackgroundColor="White"
                                            TextColor="Black"
                                            BorderColor="Black"
                                            BorderWidth="1"
                                            CornerRadius="4"
                                            Padding="0"
                                            Command="{Binding Source={x:Reference ThisPage},Path=DecreaseCommand}"
                                            CommandParameter="{Binding}"/>

                                        <!-- 数量 -->
                                        <Label Grid.Column="1"
                                           Text="{Binding Quantity}"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center"
                                           Margin="4,0"/>

                                        <!-- ＋ボタン -->
                                        <Button Grid.Column="2"
                                            Text="＋"
                                            FontSize="20"
                                            WidthRequest="24"
                                            HeightRequest="24"
                                            BackgroundColor="White"
                                            TextColor="Black"
                                            BorderColor="Black"
                                            BorderWidth="1"
                                            CornerRadius="4"
                                            Padding="0"
                                            Command="{Binding Source={x:Reference ThisPage},Path=IncreaseCommand}"
                                            CommandParameter="{Binding}"/>
                                    </Grid>

                                    <!-- 消費期限 -->
                                    <Label Grid.Column="4"
                                       Text="{Binding ExpireDate}"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"/>

                                    <!-- カテゴリ -->
                                    <Label Grid.Column="6"
                                       Text="{Binding Category}"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"/>

                                    <!-- 削除ボタン -->
                                    <ImageButton Grid.Column="8"
                                         Source="delete.png"
                                                 BackgroundColor="Transparent"
                                                 BorderWidth="0"
                                         WidthRequest="30"
                                         HeightRequest="30"
                                         Command="{Binding Source={x:Reference ThisPage}, Path=DeleteCommand}"
                                         CommandParameter="{Binding}"/>
                                </Grid>

                                <!-- 商品間の区切り線 -->
                                <BoxView HeightRequest="0.5"
                                     BackgroundColor="Black"
                                     MaximumWidthRequest="750"/>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- 商品登録ボタン -->
                <Grid Grid.Row="3">
                    <Button Text="{Binding Btn_AddProduct}"
                            HorizontalOptions="End"
                            WidthRequest="200"
                            FontSize="15"
                            CornerRadius="10"
                            BackgroundColor="#B2BEB5"
                            TextColor="White"
                            Margin="10,0"
                            Clicked="OnRegisterClicked"/>
                </Grid>

            </Grid>

        </base:BasePage.InnerContent>
    </base:BasePage>
</ContentPage>
 