<ContentPage
    x:Class="LocalDisasterPreventionInformationApp.Pages.Setting.EditProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:LocalDisasterPreventionInformationApp.Pages.Base"
    Shell.NavBarIsVisible="False">

    <base:BasePage>
        <base:BasePage.InnerContent>
            <Grid x:Name="Inner" RowDefinitions="*,Auto">

                <ScrollView Grid.Row="0">
                    <VerticalStackLayout Padding="20" Spacing="40">

                        <!-- 情報一覧 -->
                        <Grid WidthRequest="700"
                              ColumnDefinitions="*"
                              RowDefinitions="Auto,10,Auto,20,
                              Auto,10,Auto,20,
                              Auto,10,Auto,20,
                              Auto,10,Auto,20,
                              Auto,10,Auto">

                            <!-- 氏名 -->
                            <Label Grid.Row="0"
                                   Text="氏名"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="#333"
                                   WidthRequest="650"
                                   HorizontalOptions="Start"/>

                            <Entry x:Name="nameEntry"
                                   Grid.Row="2"
                                   Text="{Binding UserName}"
                                   FontSize="26"
                                   TextColor="#000"
                                   WidthRequest="650"
                                   HorizontalOptions="Start"/>

                            <!-- フリガナ（氏名の下に移動 & サイズ統一） -->
                            <Label Grid.Row="4"
                                   Text="フリガナ"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="#333"
                                   WidthRequest="650"
                                   HorizontalOptions="Start"/>

                            <Entry x:Name="furiganaEntry"
                                   Grid.Row="6"
                                   Text="{Binding Furigana}"
                                   FontSize="26"
                                   WidthRequest="650"
                                   TextColor="#000"
                                   HorizontalOptions="Start"/>

                            <!-- メールアドレス -->
                            <Label Grid.Row="8"
                                   Text="メールアドレス"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="#333"
                                   WidthRequest="650"
                                   HorizontalOptions="Start"/>

                            <Entry x:Name="emailEntry"
                                   Grid.Row="10"
                                   Text="{Binding Email}"
                                   FontSize="26"
                                   TextColor="#000"
                                   WidthRequest="650"
                                   HorizontalOptions="Start"/>

                            <!-- 電話番号 -->
                            <Label Grid.Row="12"
                                   Text="電話番号"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="#333"
                                   WidthRequest="650"
                                   HorizontalOptions="Start"/>

                            <Entry x:Name="phoneEntry"
                                   Grid.Row="14"
                                   Text="{Binding Phone}"
                                   FontSize="26"
                                   TextColor="#000"
                                   WidthRequest="650"
                                   HorizontalOptions="Start"/>

                            <!-- 住所 -->
                            <Label Grid.Row="16"
                                   Text="住所"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="#333"
                                   HorizontalOptions="Start"/>

                            <Button Grid.Row="16"
                                    Grid.Column="1"
                                    Text="+"
                                    FontSize="20"
                                    BackgroundColor="#8CAFA4"
                                    TextColor="White"
                                    CornerRadius="10"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    HorizontalOptions="End"
                                    Margin="5,0,50,0"
                                    Clicked="OnAddAddressClicked"/>

                            <!-- AddressContainer（名前そのまま） -->
                            <VerticalStackLayout x:Name="AddressContainer"
                                                 Grid.Row="18"
                                                 Spacing="20">

                                <Grid ColumnDefinitions="Auto,10,Auto,10,*">

                                    <Entry x:Name="addressTypeEntry"
                                           Grid.Column="0"
                                           Text="{Binding AddressType}"
                                           FontSize="26"
                                           TextColor="#000"
                                           WidthRequest="100"/>

                                    <Entry x:Name="addressEntry"
                                           Grid.Column="2"
                                           Text="{Binding Address}"
                                           FontSize="26"
                                           TextColor="#000"/>

                                </Grid>

                                <BoxView HeightRequest="2"
                                         BackgroundColor="#bbb"
                                         HorizontalOptions="Fill"/>
                            </VerticalStackLayout>

                        </Grid>
                    </VerticalStackLayout>
                </ScrollView>

                <Grid Grid.Row="1"
                      Padding="20"
                      ColumnDefinitions="*,Auto,Auto,*">
                    <!-- 破棄ボタン -->
                    <Button Text="キャンセル"
                            FontSize="20"
                            BackgroundColor="#B2BEB5"
                            TextColor="White"
                            Grid.Column="1"
                            CornerRadius="10"
                            WidthRequest="170"
                            Margin="10,0"
                            Clicked="OnBackClicked"/>

                    <!-- 確定ボタン -->
                    <Button Text="確定"
                            FontSize="20"
                            BackgroundColor="#8CAFA4"
                            TextColor="White"
                            Grid.Column="2"
                            CornerRadius="10"
                            WidthRequest="170"
                            Margin="10,0"
                            Clicked="OnSubmitClicked"/>
                </Grid>
            </Grid>
        </base:BasePage.InnerContent>
    </base:BasePage>
</ContentPage>