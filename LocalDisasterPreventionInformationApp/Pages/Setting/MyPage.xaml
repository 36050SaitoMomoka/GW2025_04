<ContentPage
    x:Class="LocalDisasterPreventionInformationApp.Pages.Setting.MyPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:LocalDisasterPreventionInformationApp.Pages.Base"
    Shell.NavBarIsVisible="False">

    <base:BasePage>
        <base:BasePage.InnerContent>
            <Grid x:Name="Inner">

                <ScrollView>
                    <VerticalStackLayout Padding="20" Spacing="30">

                        <!-- 編集ボタン -->
                        <HorizontalStackLayout HorizontalOptions="End">
                            <Button Text="編集"
                                    HeightRequest="45"
                                    CornerRadius="8"
                                    BackgroundColor="#B2BEB5"
                                    TextColor="White"
                                    FontSize="18"
                                    Command="{Binding EditProfileCommand}"
                                    Clicked="OnEditButtonClick"/>
                        </HorizontalStackLayout>

                        <!-- 情報一覧（大枠） -->
                        <Border BackgroundColor="White"
                                Stroke="#5C4033"
                                StrokeThickness="3"
                                Padding="40"
                                Margin="20"
                                StrokeShape="RoundRectangle 20"
                                WidthRequest="520"
                                HorizontalOptions="Center">

                            <Grid WidthRequest="420"
                                  ColumnDefinitions="Auto,Auto,*"
                                  RowDefinitions="Auto,30,Auto,30,Auto,30,Auto">

                                <!-- 氏名（中央配置） -->
                                <VerticalStackLayout Grid.Row="0" Grid.ColumnSpan="3"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center"
                                                     Spacing="2">

                                    <Label Text="{Binding UserName}"
                                           FontSize="24"
                                           FontAttributes="Bold"
                                           TextColor="#000"
                                           HorizontalOptions="Center"/>

                                    <Label Text="{Binding Furigana}"
                                           FontSize="14"
                                           TextColor="#555"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>

                                <!-- メール + 電話 -->
                                <Grid Grid.Row="2" Grid.ColumnSpan="3"
                                      ColumnDefinitions="*,*"
                                      ColumnSpacing="12">

                                    <!-- メール枠 -->
                                    <Grid Grid.Column="0" HeightRequest="100">

                                        <Border BackgroundColor="White"
                                                Stroke="#5C4033"
                                                StrokeThickness="3"
                                                Padding="12"
                                                StrokeShape="RoundRectangle 15"/>

                                        <Label Text="メールアドレス"
                                               BackgroundColor="White"
                                               Padding="6,0"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="Black"
                                               HorizontalOptions="Start"
                                               VerticalOptions="Start"
                                               Margin="12,-10,0,0"/>

                                        <Label Text="{Binding Email}"
                                               FontSize="20"
                                               TextColor="#000"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Grid>

                                    <!-- 電話枠 -->
                                    <Grid Grid.Column="1" HeightRequest="100">

                                        <Border BackgroundColor="White"
                                                Stroke="#5C4033"
                                                StrokeThickness="3"
                                                Padding="12"
                                                StrokeShape="RoundRectangle 15"/>

                                        <Label Text="電話番号"
                                               BackgroundColor="White"
                                               Padding="6,0"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="Black"
                                               HorizontalOptions="Start"
                                               VerticalOptions="Start"
                                               Margin="12,-10,0,0"/>

                                        <Label Text="{Binding Phone}"
                                               FontSize="20"
                                               TextColor="#000"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Grid>

                                </Grid>

                                <!-- 住所 -->
                                <Grid Grid.Row="4" Grid.ColumnSpan="3">

                                    <Border BackgroundColor="White"
                                            Stroke="#5C4033"
                                            StrokeThickness="3"
                                            Padding="12"
                                            StrokeShape="RoundRectangle 15"/>

                                    <Label Text="住所"
                                           BackgroundColor="White"
                                           Padding="6,0"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="Black"
                                           HorizontalOptions="Start"
                                           VerticalOptions="Start"
                                           Margin="12,-10,0,0"/>

                                    <VerticalStackLayout x:Name="AddressContainer"
                                                         Padding="12"
                                                         Spacing="6"
                                                         HorizontalOptions="Center"
                                                         VerticalOptions="Start"/>
                                </Grid>

                            </Grid>
                        </Border>

                    </VerticalStackLayout>
                </ScrollView>

            </Grid>
        </base:BasePage.InnerContent>
    </base:BasePage>

</ContentPage>